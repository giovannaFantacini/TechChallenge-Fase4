# Copie para .env e ajuste conforme necessário.

# --- Coleta de dados ---
# Um modelo é treinado por ticker. Liste os tickers separados por vírgula.
SYMBOLS=DIS,AAPL,MSFT
START_DATE=2020-01-01
END_DATE=2026-07-01
TARGET_COLUMN=Close

# --- Janela / split ---
SEQUENCE_LENGTH=60
TRAIN_SPLIT=0.8

# --- Hiperparâmetros LSTM ---
LSTM_UNITS=64
LSTM_LAYERS=2
DROPOUT=0.2
LEARNING_RATE=0.001
EPOCHS=100
BATCH_SIZE=32
PATIENCE=12
